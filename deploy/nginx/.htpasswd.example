# ──────────────────────────────────────────────
# Credenciales para Basic Auth de Prisma Studio
# ──────────────────────────────────────────────
# Generar con:
#   htpasswd -nb usuario password
#
# O con OpenSSL:
#   echo "usuario:$(openssl passwd -apr1 password)" > .htpasswd
#
# Copiar este archivo a .htpasswd y reemplazar con tus credenciales.
# .htpasswd está en .gitignore — no se sube al repositorio.
# ──────────────────────────────────────────────
# usuario:$apr1$xxxxxxxx$xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
