generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  extensions   = [vector(map: "vector")]
}

enum TaskStatus {
  pending
  in_progress
  completed
  postponed
  cancelled

  @@map("task_status")
}

enum TaskPriority {
  low
  medium
  high

  @@map("task_priority")
}

enum ObjectiveStatus {
  active
  paused
  completed
  cancelled

  @@map("objective_status")
}

enum JobStatus {
  pending
  processing
  completed
  failed

  @@map("job_status")
}

enum JobSource {
  websocket
  scheduled
  system

  @@map("job_source")
}

enum ConversationRole {
  user
  assistant
  system

  @@map("conversation_role")
}

enum ListStatus {
  active
  completed
  cancelled

  @@map("list_status")
}

enum EventStatus {
  active
  completed
  cancelled

  @@map("event_status")
}

enum ProjectStatus {
  active
  paused
  completed
  cancelled

  @@map("project_status")
}

enum IdeaStatus {
  new_idea
  evaluating
  approved
  discarded
  converted

  @@map("idea_status")
}

enum EntityType {
  task
  objective
  project
  idea
  list
  event

  @@map("entity_type")
}

model Task {
  id               String         @id @default(uuid()) @db.Uuid
  title            String
  description      String?
  status           TaskStatus     @default(pending)
  dueDate          DateTime?      @map("due_date") @db.Timestamptz()
  priority         TaskPriority   @default(medium)
  context          Json?          @default("{}") @db.JsonB
  objectiveId      String?        @map("objective_id") @db.Uuid
  reminderAt       DateTime?      @map("reminder_at") @db.Timestamptz()
  reminderFiredAt  DateTime?      @map("reminder_fired_at") @db.Timestamptz()
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz()
  cancelledAt      DateTime?      @map("cancelled_at") @db.Timestamptz()

  objective Objective? @relation(fields: [objectiveId], references: [id])

  @@index([reminderAt, reminderFiredAt])
  @@map("tasks")
}

model Objective {
  id          String          @id @default(uuid()) @db.Uuid
  title       String
  description String?
  deadline    DateTime?       @db.Timestamptz()
  status      ObjectiveStatus @default(active)
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime        @updatedAt @map("updated_at") @db.Timestamptz()
  cancelledAt DateTime?       @map("cancelled_at") @db.Timestamptz()

  tasks Task[]

  @@map("objectives")
}

model Memory {
  id        String   @id @default(uuid()) @db.Uuid
  content   String
  embedding Unsupported("vector(1536)")?
  metadata  Json?    @default("{}") @db.JsonB
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("memories")
}

model ConversationTurn {
  id        String            @id @default(uuid()) @db.Uuid
  sessionId String            @map("session_id") @db.Uuid
  role      ConversationRole
  content   String
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz()

  @@index([sessionId, createdAt(sort: Desc)], type: BTree)
  @@map("conversation_turns")
}

model Job {
  id            String    @id @default(uuid()) @db.Uuid
  correlationId String    @map("correlation_id") @db.Uuid
  sessionId     String    @map("session_id") @db.Uuid
  type          String
  source        JobSource @default(websocket)
  payload       Json      @db.JsonB
  status        JobStatus @default(pending)
  attempts      Int       @default(0)
  maxAttempts   Int       @default(3) @map("max_attempts")
  runAt         DateTime  @default(now()) @map("run_at") @db.Timestamptz()
  lockedAt      DateTime? @map("locked_at") @db.Timestamptz()
  lockedBy      String?   @map("locked_by")
  result        Json?     @db.JsonB
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([status, runAt], type: BTree)
  @@index([lockedBy], type: BTree)
  @@index([correlationId], type: BTree)
  @@index([sessionId], type: BTree)
  @@map("jobs")
}

model Device {
  id        String   @id @default(uuid()) @db.Uuid
  fcmToken  String   @map("fcm_token")
  platform  String   @default("unknown")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  @@unique([fcmToken])
  @@map("devices")
}

model Event {
  id              String       @id @default(uuid()) @db.Uuid
  title           String
  description     String?
  location        String?
  category        String?
  startTime       DateTime     @map("start_time") @db.Timestamptz()
  endTime         DateTime?    @map("end_time") @db.Timestamptz()
  status          EventStatus  @default(active)
  recurrenceRule  Json?        @map("recurrence_rule") @db.JsonB
  parentId        String?      @map("parent_id") @db.Uuid
  isException     Boolean      @default(false) @map("is_exception")
  exceptionDate   DateTime?    @map("exception_date") @db.Timestamptz()
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz()
  cancelledAt     DateTime?    @map("cancelled_at") @db.Timestamptz()

  parent      Event?         @relation("EventExceptions", fields: [parentId], references: [id])
  exceptions  Event[]        @relation("EventExceptions")

  @@index([startTime])
  @@index([parentId])
  @@map("events")
}

model Project {
  id          String        @id @default(uuid()) @db.Uuid
  title       String
  description String?
  status      ProjectStatus @default(active)
  category    String?
  deadline    DateTime?     @db.Timestamptz()
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz()
  cancelledAt DateTime?     @map("cancelled_at") @db.Timestamptz()

  @@map("projects")
}

model Idea {
  id          String     @id @default(uuid()) @db.Uuid
  title       String
  description String?
  status      IdeaStatus @default(new_idea)
  tags        String[]   @default([])
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("ideas")
}

model EntityLink {
  id         String     @id @default(uuid()) @db.Uuid
  sourceType EntityType @map("source_type")
  sourceId   String     @map("source_id") @db.Uuid
  targetType EntityType @map("target_type")
  targetId   String     @map("target_id") @db.Uuid
  relation   String     @default("related")
  note       String?
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz()

  @@unique([sourceType, sourceId, targetType, targetId])
  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@map("entity_links")
}

model List {
  id          String     @id @default(uuid()) @db.Uuid
  title       String
  description String?
  type        String     @default("general")
  status      ListStatus @default(active)
  items       Json?      @default("[]") @db.JsonB
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz()
  cancelledAt DateTime?  @map("cancelled_at") @db.Timestamptz()

  @@map("lists")
}
